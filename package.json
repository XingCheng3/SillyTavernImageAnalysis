{
  "name": "sillytavern-image-analysis",
  "version": "1.0.0",
  "description": "Local-first workspace for SillyTavern character cards and lorebooks with editing, AI translation, AI generation, patching, and PNG export.",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/XingCheng3/SillyTavernImageAnalysis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XingCheng3/SillyTavernImageAnalysis.git"
  },
  "bugs": {
    "url": "https://github.com/XingCheng3/SillyTavernImageAnalysis/issues"
  },
  "keywords": [
    "sillytavern",
    "character-card",
    "lorebook",
    "worldbook",
    "png",
    "ai-translation",
    "ai-generation",
    "vue3",
    "vite",
    "local-first"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && sh ./scripts/deploy-bt.sh",
    "build:only": "vite build",
    "deploy:bt": "sh ./scripts/deploy-bt.sh",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.vue",
    "test:parser": "node tests/characterCardParser.test.js",
    "test:worldbook-ai": "node tests/worldBookAIGeneration.test.js && node tests/worldBookAIPatchPlanner.test.js",
    "test:character-ai": "node tests/characterAICreation.test.js",
    "test:all": "npm run test:parser && npm run test:worldbook-ai && npm run test:character-ai"
  },
  "dependencies": {
    "@azure/identity": "^4.0.1",
    "@azure/msal-node": "^2.6.4",
    "@element-plus/icons-vue": "^2.1.0",
    "@knight0zh/mssql-mcp-server": "latest",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@types/node": "^22.14.1",
    "axios": "^1.4.0",
    "element-plus": "^2.3.9",
    "highlight.js": "^11.11.1",
    "js-cookie": "^3.0.5",
    "marked": "^15.0.8",
    "mssql": "^10.0.4",
    "pako": "^2.1.0",
    "pinia": "^2.1.6",
    "tedious": "^16.7.1",
    "uuid": "^11.1.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@iconify/json": "^2.2.323",
    "@vitejs/plugin-vue": "^4.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.86.3",
    "terser": "^5.43.1",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-icons": "^22.1.0",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^4.4.9",
    "vue-eslint-parser": "^9.4.3"
  }
}
